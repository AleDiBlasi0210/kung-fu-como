{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "dev",
			"type": "shell",
			"command": "npm.cmd",
			"args": [
				"run",
				"dev"
			],
			"isBackground": true,
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": []
		},
		{
			"label": "studio:dev",
			"type": "shell",
			"command": "npm.cmd",
			"args": [
				"run",
				"studio:dev"
			],
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "build",
			"type": "shell",
			"command": "npm.cmd",
			"args": [
				"run",
				"build"
			],
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "start",
			"type": "shell",
			"command": "npm.cmd",
			"args": [
				"run",
				"start"
			],
			"problemMatcher": []
		},
		{
			"label": "lint",
			"type": "shell",
			"command": "npm.cmd",
			"args": [
				"run",
				"lint"
			],
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "typecheck",
			"type": "shell",
			"command": "npx.cmd",
			"args": [
				"tsc",
				"--noEmit"
			],
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "git-commit-and-deploy",
			"type": "shell",
			"command": "git",
			"args": [
				"add",
				".",
				";",
				"git",
				"commit",
				"-m",
				"\"chore: update contatti layout and deploy\"",
				";",
				"git",
				"push",
				"origin",
				"main"
			],
			"isBackground": false
		},
		{
			"label": "git-commit-and-deploy-fix",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"git add .; git commit -m 'chore: update contatti layout and deploy'; git push origin main"
			],
			"isBackground": false
		},
		{
			"label": "git-commit-and-deploy-cmd",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"git add . && git commit -m \"chore: update contatti layout and deploy\" && git push origin main"
			],
			"isBackground": false
		},
		{
			"label": "git-commit-and-deploy-safe",
			"type": "shell",
			"command": "git add .; git commit -m chore-deploy-contatti; git push origin main",
			"isBackground": false
		}
	]
}