# Public website (read-only Sanity content)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: dedicated Studio variables (used by sanity.config.ts / sanity.cli.ts)
SANITY_STUDIO_PROJECT_ID=your_project_id
SANITY_STUDIO_DATASET=production

# GitHub Pages base path (set in CI)
BASE_PATH=/kung-fu-como
NEXT_PUBLIC_BASE_PATH=/kung-fu-como

# Site URL for sitemap/metadata
NEXT_PUBLIC_SITE_URL=https://www.kungfucomo.org
